<!DOCTYPE html>
<html>
<head>
    <title>Admin Login</title>
</head>
<body>
    <h1>Admin Login</h1>
    <% if (error) { %>
        <p style="color:red;">
            <%= error %>
        </p>
    <% } %>
    <form action="/login" method="POST">

        <div>
            <label>Username</label>

            <input
                type="text"
                name="username"
                required
            >
        </div>

        <br>

        <div>
            <label>Password</label>

            <input
                type="password"
                name="password"
                required
            >
        </div>

        <br>

        <button type="submit">
            Login
        </button>
    </form>
</body>
</html>