<!DOCTYPE html>
<html>
<head>
    <title>Admin Login</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav class="navbar">
        <a href="/">My Blog</a>

        <div>
            <a href="/admin">Dashboard</a>
        </div>
    </nav>
    <h1>Admin Login</h1>
    <% if (error) { %>
        <p class="error-message">
            <%= error %>
        </p>
    <% } %>
    <form action="/login" method="POST">

        <div>
            <label>Username</label>

            <input
                type="text"
                name="username"
                required
            >
        </div>

        <br>

        <div>
            <label>Password</label>

            <input
                type="password"
                name="password"
                required
            >
        </div>

        <br>

        <button type="submit">
            Login
        </button>
    </form>
</body>
</html>